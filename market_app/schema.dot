  // Relations

  market_app_models_Seller -> market_app_models_Market
  [label=" markets (sellers)"] [arrowhead=arrowtail arrowtail=arrowtail, dir=both];

  market_app_models_Product -> market_app_models_Seller
  [label=" seller (products)"] [arrowhead=none, arrowtail=dot, dir=both];

  market_app_models_Product -> market_app_models_Market
  [label=" market (products)"] [arrowhead=none, arrowtail=dot, dir=both];


